{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GBeurier/dag-ml/schemas/training_influence_manifest.v1.schema.json",
  "title": "DAG-ML TrainingInfluenceManifest v1",
  "description": "Exact physical-sample and origin closures that influenced fitting, selection, early stopping, weighting or trained aggregation. The manifest deliberately has no TrainingOutcome back-reference; a PredictorBinding binds their sibling fingerprints.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "relation_fingerprint", "entries", "manifest_fingerprint"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "relation_fingerprint": {
      "$ref": "#/$defs/sha256"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/training_influence_entry"
      },
      "description": "Canonical order is (kind order, scope_id, node_id); duplicate scope coordinates are invalid."
    },
    "manifest_fingerprint": {
      "$ref": "#/$defs/sha256",
      "description": "DAG-ML TCV1 SHA-256 of the complete manifest with only manifest_fingerprint omitted."
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "training_influence_kind": {
      "enum": [
        "transform_fit",
        "model_fit",
        "hpo_selection",
        "early_stopping",
        "weighting_resampling",
        "trained_meta_aggregation"
      ]
    },
    "sorted_identifiers": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      },
      "description": "Lexicographically sorted unique identifiers; semantic validation enforces ordering."
    },
    "physical_sample_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "training_influence_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "scope_id",
        "node_id",
        "physical_sample_ids",
        "origin_sample_ids",
        "group_ids"
      ],
      "properties": {
        "kind": {
          "$ref": "#/$defs/training_influence_kind"
        },
        "scope_id": {
          "$ref": "#/$defs/identifier"
        },
        "node_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/identifier"
            },
            {
              "type": "null"
            }
          ]
        },
        "physical_sample_ids": {
          "$ref": "#/$defs/physical_sample_ids"
        },
        "origin_sample_ids": {
          "$ref": "#/$defs/sorted_identifiers"
        },
        "group_ids": {
          "$ref": "#/$defs/sorted_identifiers"
        }
      }
    }
  }
}
