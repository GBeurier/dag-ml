{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GBeurier/dag-ml/schemas/prediction_cache_columnar_tensor_metadata.v1.schema.json",
  "title": "DAG-ML Prediction Cache Columnar Tensor Metadata v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "requirement_key",
    "cache_id",
    "prediction_level",
    "block_count",
    "row_count",
    "rows",
    "cols",
    "layout",
    "target_names",
    "column_offsets",
    "blocks"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "requirement_key": {
      "type": "string",
      "minLength": 1
    },
    "cache_id": {
      "type": "string",
      "minLength": 1
    },
    "prediction_level": {
      "enum": ["sample", "target", "group"]
    },
    "relation_fingerprint": {
      "anyOf": [
        { "$ref": "#/$defs/sha256" },
        { "type": "null" }
      ]
    },
    "evaluation_scope": {
      "anyOf": [
        { "$ref": "#/$defs/evaluation_scope" },
        { "type": "null" }
      ]
    },
    "reduction_id": {
      "anyOf": [
        { "$ref": "#/$defs/non_empty_string" },
        { "type": "null" }
      ]
    },
    "block_count": {
      "type": "integer",
      "minimum": 1
    },
    "row_count": {
      "type": "integer",
      "minimum": 1
    },
    "rows": {
      "type": "integer",
      "minimum": 1
    },
    "cols": {
      "type": "integer",
      "minimum": 1
    },
    "layout": {
      "const": "column_major_f64"
    },
    "target_names": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "column_offsets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "integer",
        "minimum": 0
      }
    },
    "blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/block_metadata"
      }
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9A-Fa-f]{64}$"
    },
    "evaluation_scope": {
      "enum": ["oof", "holdout", "final", "train", "refit"]
    },
    "block_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "block_index",
        "prediction_id",
        "fold_id",
        "row_offset",
        "row_count",
        "sample_ids",
        "unit_ids"
      ],
      "properties": {
        "block_index": {
          "type": "integer",
          "minimum": 0
        },
        "prediction_id": {
          "type": ["string", "null"]
        },
        "fold_id": {
          "type": ["string", "null"]
        },
        "relation_fingerprint": {
          "anyOf": [
            { "$ref": "#/$defs/sha256" },
            { "type": "null" }
          ]
        },
        "evaluation_scope": {
          "anyOf": [
            { "$ref": "#/$defs/evaluation_scope" },
            { "type": "null" }
          ]
        },
        "reduction_id": {
          "anyOf": [
            { "$ref": "#/$defs/non_empty_string" },
            { "type": "null" }
          ]
        },
        "row_offset": {
          "type": "integer",
          "minimum": 0
        },
        "row_count": {
          "type": "integer",
          "minimum": 1
        },
        "sample_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unit_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/prediction_unit_id"
          }
        }
      }
    },
    "prediction_unit_id": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "id"],
      "properties": {
        "level": {
          "enum": ["sample", "target", "group"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
