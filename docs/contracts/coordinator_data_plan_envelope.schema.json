{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GBeurier/dag-ml/schemas/coordinator_data_plan_envelope.v1.schema.json",
  "title": "DAG-ML Coordinator Data Plan Envelope",
  "type": "object",
  "required": ["schema_version", "schema_fingerprint", "plan_fingerprint", "plan"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "schema_fingerprint": {
      "$ref": "#/$defs/sha256"
    },
    "plan_fingerprint": {
      "$ref": "#/$defs/sha256"
    },
    "relation_fingerprint": {
      "anyOf": [
        { "$ref": "#/$defs/sha256" },
        { "type": "null" }
      ]
    },
    "data_content_fingerprint": {
      "anyOf": [
        { "$ref": "#/$defs/sha256" },
        { "type": "null" }
      ],
      "description": "Additive V1 identity of concrete feature/input content. Legacy envelopes may omit it; TrainingRequest v1 requires the corresponding TrainingDataIdentity value."
    },
    "target_content_fingerprint": {
      "anyOf": [
        { "$ref": "#/$defs/sha256" },
        { "type": "null" }
      ],
      "description": "Additive V1 identity of concrete target content; prediction-only envelopes may omit it."
    },
    "plan": {
      "type": "object",
      "required": ["id", "steps", "output_representation"],
      "additionalProperties": true
    },
    "coordinator_relations": {
      "anyOf": [
        { "$ref": "#/$defs/coordinator_relation_set" },
        { "type": "null" }
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9A-Fa-f]{64}$"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "entity_unit_level": {
      "enum": ["physical_sample", "source_sample", "observation", "combo"]
    },
    "coordinator_relation_set": {
      "type": "object",
      "required": ["records"],
      "properties": {
        "records": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/coordinator_relation"
          }
        }
      },
      "additionalProperties": false
    },
    "coordinator_relation": {
      "type": "object",
      "required": ["observation_id", "sample_id"],
      "properties": {
        "unit_level": {
          "$ref": "#/$defs/entity_unit_level",
          "default": "observation"
        },
        "unit_id": {
          "anyOf": [
            { "$ref": "#/$defs/id" },
            { "type": "null" }
          ]
        },
        "observation_id": {
          "$ref": "#/$defs/id"
        },
        "sample_id": {
          "$ref": "#/$defs/id"
        },
        "source_id": {
          "anyOf": [
            { "$ref": "#/$defs/id" },
            { "type": "null" }
          ]
        },
        "rep_id": {
          "anyOf": [
            { "$ref": "#/$defs/id" },
            { "type": "null" }
          ]
        },
        "target_id": {
          "anyOf": [
            { "$ref": "#/$defs/id" },
            { "type": "null" }
          ]
        },
        "group_id": {
          "anyOf": [
            { "$ref": "#/$defs/id" },
            { "type": "null" }
          ]
        },
        "origin_sample_id": {
          "anyOf": [
            { "$ref": "#/$defs/id" },
            { "type": "null" }
          ]
        },
        "derived_unit_id": {
          "anyOf": [
            { "$ref": "#/$defs/id" },
            { "type": "null" }
          ]
        },
        "component_observation_ids": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "sample_influence_weight": {
          "anyOf": [
            {
              "type": "number",
              "exclusiveMinimum": 0
            },
            { "type": "null" }
          ]
        },
        "quality_flag": {
          "anyOf": [
            { "$ref": "#/$defs/id" },
            { "type": "null" }
          ]
        },
        "is_augmented": {
          "type": "boolean",
          "default": false
        },
        "excluded": {
          "type": "boolean",
          "default": false
        },
        "metadata": {
          "type": "object",
          "default": {}
        },
        "tags": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "default": [],
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  }
}
