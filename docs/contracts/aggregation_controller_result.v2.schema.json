{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GBeurier/dag-ml/schemas/aggregation_controller_result.v2.schema.json",
  "title": "DAG-ML Aggregation Controller Result v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "output"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "task_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "reduction_plan": {
      "anyOf": [
        {
          "$ref": "#/$defs/reduction_plan"
        },
        {
          "type": "null"
        }
      ]
    },
    "output": {
      "oneOf": [
        {
          "$ref": "#/$defs/sample_output"
        },
        {
          "$ref": "#/$defs/unit_output"
        }
      ]
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:-]{1,128}$"
    },
    "prediction_level": {
      "enum": [
        "observation",
        "sample",
        "target",
        "group"
      ]
    },
    "entity_unit_level": {
      "enum": [
        "physical_sample",
        "source_sample",
        "observation",
        "combo"
      ]
    },
    "prediction_partition": {
      "enum": [
        "train",
        "validation",
        "test",
        "final"
      ]
    },
    "aggregation_weights": {
      "enum": [
        "none",
        "quality",
        "repetition_count",
        "controller_emitted"
      ]
    },
    "reduction_role": {
      "enum": [
        "score",
        "persist",
        "fold_ensemble",
        "meta_feature",
        "final_output"
      ]
    },
    "reduction_axis": {
      "enum": [
        "unit",
        "fold",
        "model",
        "metric"
      ]
    },
    "reduction_method": {
      "enum": [
        "mean",
        "weighted_mean",
        "median",
        "vote",
        "robust_mean",
        "exclude_outliers",
        "custom"
      ]
    },
    "reduction_task_compatibility": {
      "enum": [
        "any",
        "regression",
        "classification"
      ]
    },
    "aggregation_controller_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "controller_id"
      ],
      "properties": {
        "controller_id": {
          "$ref": "#/$defs/identifier"
        },
        "params": {
          "not": {
            "type": "null"
          }
        }
      }
    },
    "reduction_plan": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "role": {
          "$ref": "#/$defs/reduction_role"
        },
        "axis": {
          "$ref": "#/$defs/reduction_axis"
        },
        "input_unit_level": {
          "$ref": "#/$defs/entity_unit_level"
        },
        "output_unit_level": {
          "$ref": "#/$defs/entity_unit_level"
        },
        "method": {
          "$ref": "#/$defs/reduction_method"
        },
        "weight_source": {
          "$ref": "#/$defs/aggregation_weights"
        },
        "task_compatibility": {
          "$ref": "#/$defs/reduction_task_compatibility"
        },
        "custom_controller": {
          "anyOf": [
            {
              "$ref": "#/$defs/aggregation_controller_spec"
            },
            {
              "type": "null"
            }
          ]
        },
        "params": {
          "type": "object"
        }
      }
    },
    "sample_output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "output_kind",
        "block"
      ],
      "properties": {
        "output_kind": {
          "const": "sample"
        },
        "block": {
          "$ref": "#/$defs/prediction_block"
        }
      }
    },
    "unit_output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "output_kind",
        "block"
      ],
      "properties": {
        "output_kind": {
          "const": "unit"
        },
        "block": {
          "$ref": "#/$defs/aggregated_prediction_block"
        }
      }
    },
    "prediction_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer_node",
        "producer_port",
        "partition",
        "fold_id",
        "sample_ids",
        "values",
        "target_names"
      ],
      "properties": {
        "prediction_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "producer_node": {
          "$ref": "#/$defs/identifier"
        },
        "producer_port": {
          "$ref": "#/$defs/non_empty_string"
        },
        "partition": {
          "$ref": "#/$defs/prediction_partition"
        },
        "fold_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "sample_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "values": {
          "$ref": "#/$defs/f64_matrix"
        },
        "target_names": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "aggregated_prediction_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer_node",
        "producer_port",
        "partition",
        "fold_id",
        "level",
        "unit_ids",
        "values",
        "target_names"
      ],
      "properties": {
        "prediction_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "producer_node": {
          "$ref": "#/$defs/identifier"
        },
        "producer_port": {
          "$ref": "#/$defs/non_empty_string"
        },
        "partition": {
          "$ref": "#/$defs/prediction_partition"
        },
        "fold_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "level": {
          "$ref": "#/$defs/prediction_level"
        },
        "unit_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/prediction_unit_id"
          }
        },
        "values": {
          "$ref": "#/$defs/f64_matrix"
        },
        "target_names": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "prediction_unit_id": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "id"
      ],
      "properties": {
        "level": {
          "enum": [
            "sample",
            "target",
            "group"
          ]
        },
        "id": {
          "$ref": "#/$defs/identifier"
        }
      }
    },
    "f64_matrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "number"
        }
      }
    }
  }
}
