{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GBeurier/dag-ml/schemas/aggregation_controller_result.v1.schema.json",
  "title": "DAG-ML Aggregation Controller Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task_id", "output"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "task_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "output": {
      "oneOf": [
        { "$ref": "#/$defs/sample_output" },
        { "$ref": "#/$defs/unit_output" }
      ]
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:-]{1,128}$"
    },
    "prediction_level": {
      "enum": ["observation", "sample", "target", "group"]
    },
    "prediction_partition": {
      "enum": ["train", "validation", "test", "final"]
    },
    "sample_output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output_kind", "block"],
      "properties": {
        "output_kind": {
          "const": "sample"
        },
        "block": {
          "$ref": "#/$defs/prediction_block"
        }
      }
    },
    "unit_output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output_kind", "block"],
      "properties": {
        "output_kind": {
          "const": "unit"
        },
        "block": {
          "$ref": "#/$defs/aggregated_prediction_block"
        }
      }
    },
    "prediction_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["producer_node", "partition", "fold_id", "sample_ids", "values", "target_names"],
      "properties": {
        "prediction_id": {
          "type": ["string", "null"]
        },
        "producer_node": {
          "$ref": "#/$defs/identifier"
        },
        "partition": {
          "$ref": "#/$defs/prediction_partition"
        },
        "fold_id": {
          "type": ["string", "null"]
        },
        "sample_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "values": {
          "$ref": "#/$defs/f64_matrix"
        },
        "target_names": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "aggregated_prediction_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["producer_node", "partition", "fold_id", "level", "unit_ids", "values", "target_names"],
      "properties": {
        "prediction_id": {
          "type": ["string", "null"]
        },
        "producer_node": {
          "$ref": "#/$defs/identifier"
        },
        "partition": {
          "$ref": "#/$defs/prediction_partition"
        },
        "fold_id": {
          "type": ["string", "null"]
        },
        "level": {
          "$ref": "#/$defs/prediction_level"
        },
        "unit_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/prediction_unit_id" }
        },
        "values": {
          "$ref": "#/$defs/f64_matrix"
        },
        "target_names": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "prediction_unit_id": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "id"],
      "properties": {
        "level": {
          "enum": ["sample", "target", "group"]
        },
        "id": {
          "$ref": "#/$defs/identifier"
        }
      }
    },
    "f64_matrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "number" }
      }
    }
  }
}
