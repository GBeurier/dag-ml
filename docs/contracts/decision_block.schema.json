{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GBeurier/dag-ml/schemas/decision_block.v1.schema.json",
  "title": "DAG-ML DecisionBlock v1",
  "description": "Explicit application decisions derived by a named policy. Statistical intervals and domain diagnostics remain separate referenced blocks.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "block_id",
    "policy_id",
    "policy_fingerprint",
    "predictor_binding_fingerprint",
    "cohort_manifest_fingerprint",
    "conformal_block_fingerprint",
    "domain_assessment_fingerprint",
    "thresholds",
    "unit_level",
    "unit_ids",
    "decisions",
    "block_fingerprint"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "block_id": { "$ref": "#/$defs/identifier" },
    "policy_id": { "$ref": "#/$defs/identifier" },
    "policy_fingerprint": { "$ref": "#/$defs/sha256" },
    "predictor_binding_fingerprint": { "$ref": "#/$defs/sha256" },
    "cohort_manifest_fingerprint": { "$ref": "#/$defs/sha256" },
    "conformal_block_fingerprint": {
      "anyOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }]
    },
    "domain_assessment_fingerprint": {
      "anyOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }]
    },
    "thresholds": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/threshold" },
      "description": "Canonical policy thresholds used to derive the decisions. Runtime handles are forbidden semantically."
    },
    "unit_level": { "const": "physical_sample" },
    "unit_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/decision" }
    },
    "block_fingerprint": {
      "$ref": "#/$defs/sha256",
      "description": "DAG-ML TCV1 SHA-256 with block_fingerprint omitted."
    }
  },
  "anyOf": [
    {
      "properties": {
        "conformal_block_fingerprint": { "$ref": "#/$defs/sha256" }
      }
    },
    {
      "properties": {
        "domain_assessment_fingerprint": { "$ref": "#/$defs/sha256" }
      }
    }
  ],
  "$defs": {
    "identifier": {
      "$ref": "https://github.com/GBeurier/dag-ml/schemas/conformal_calibration.v1.schema.json#/$defs/identifier"
    },
    "non_empty_string": {
      "$ref": "https://github.com/GBeurier/dag-ml/schemas/conformal_calibration.v1.schema.json#/$defs/non_empty_string"
    },
    "sha256": {
      "$ref": "https://github.com/GBeurier/dag-ml/schemas/conformal_calibration.v1.schema.json#/$defs/sha256"
    },
    "threshold": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "operator", "value", "unit"],
      "properties": {
        "name": { "$ref": "#/$defs/non_empty_string" },
        "operator": { "enum": ["lt", "lte", "gt", "gte", "eq", "in", "not_in"] },
        "value": {
          "oneOf": [
            { "type": "number", "x-dagml-json-token-type": "binary64-float" },
            { "type": "string", "minLength": 1 },
            { "type": "boolean" },
            {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "oneOf": [
                  { "type": "number", "x-dagml-json-token-type": "binary64-float" },
                  { "type": "string", "minLength": 1 },
                  { "type": "boolean" }
                ]
              }
            }
          ]
        },
        "unit": {
          "anyOf": [{ "$ref": "#/$defs/non_empty_string" }, { "type": "null" }]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "operator": { "enum": ["in", "not_in"] } },
            "required": ["operator"]
          },
          "then": { "properties": { "value": { "type": "array" } } },
          "else": {
            "not": { "properties": { "value": { "type": "array" } }, "required": ["value"] }
          }
        }
      ]
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unit_id", "action", "reasons"],
      "properties": {
        "unit_id": { "$ref": "#/$defs/identifier" },
        "action": { "enum": ["accept", "reject", "refer"] },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    }
  }
}
