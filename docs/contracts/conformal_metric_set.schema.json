{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GBeurier/dag-ml/schemas/conformal_metric_set.v1.schema.json",
  "title": "DAG-ML ConformalMetricSet v1",
  "description": "Coverage and interval-quality metrics kept separate from model ScoreSet and indexed by cohort, scenario, severity and slice.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "metric_set_id",
    "calibration_artifact_id",
    "calibration_artifact_checksum",
    "predictor_binding_fingerprint",
    "point_prediction_fingerprint",
    "conformal_prediction_block_fingerprint",
    "truth_fingerprint",
    "unit_ids_fingerprint",
    "cohort_manifest_fingerprint",
    "method",
    "unit_level",
    "multi_target_policy",
    "records",
    "metric_set_fingerprint"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "metric_set_id": { "$ref": "#/$defs/identifier" },
    "calibration_artifact_id": { "$ref": "#/$defs/identifier" },
    "calibration_artifact_checksum": { "$ref": "#/$defs/sha256" },
    "predictor_binding_fingerprint": { "$ref": "#/$defs/sha256" },
    "point_prediction_fingerprint": { "$ref": "#/$defs/sha256" },
    "conformal_prediction_block_fingerprint": { "$ref": "#/$defs/sha256" },
    "truth_fingerprint": { "$ref": "#/$defs/sha256" },
    "unit_ids_fingerprint": { "$ref": "#/$defs/sha256" },
    "cohort_manifest_fingerprint": { "$ref": "#/$defs/sha256" },
    "method": { "const": "split_absolute_residual" },
    "unit_level": { "const": "physical_sample" },
    "multi_target_policy": { "enum": ["marginal", "joint_max"] },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/conformal_metric_record" }
    },
    "metric_set_fingerprint": {
      "$ref": "#/$defs/sha256",
      "description": "DAG-ML TCV1 SHA-256 with metric_set_fingerprint omitted."
    }
  },
  "$defs": {
    "identifier": {
      "$ref": "https://github.com/GBeurier/dag-ml/schemas/conformal_calibration.v1.schema.json#/$defs/identifier"
    },
    "non_empty_string": {
      "$ref": "https://github.com/GBeurier/dag-ml/schemas/conformal_calibration.v1.schema.json#/$defs/non_empty_string"
    },
    "sha256": {
      "$ref": "https://github.com/GBeurier/dag-ml/schemas/conformal_calibration.v1.schema.json#/$defs/sha256"
    },
    "slice_key": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value"],
      "properties": {
        "kind": { "enum": ["all", "group", "source", "environment", "target"] },
        "value": {
          "anyOf": [
            { "$ref": "#/$defs/non_empty_string" },
            { "type": "null" }
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "all" } }, "required": ["kind"] },
          "then": { "properties": { "value": { "type": "null" } } },
          "else": { "properties": { "value": { "$ref": "#/$defs/non_empty_string" } } }
        }
      ]
    },
    "conformal_metric_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "coverage",
        "target_name",
        "scenario_id",
        "severity",
        "slice",
        "fold_id",
        "repeat_id",
        "seed",
        "unit_ids_fingerprint",
        "sample_count",
        "measurement_status",
        "guarantee_status",
        "empirical_coverage",
        "coverage_gap",
        "mean_width",
        "median_width",
        "interval_score",
        "set_size"
      ],
      "properties": {
        "coverage": {
          "type": "number",
          "exclusiveMinimum": 0,
          "exclusiveMaximum": 1,
          "x-dagml-json-token-type": "binary64-float"
        },
        "target_name": {
          "anyOf": [{ "$ref": "#/$defs/non_empty_string" }, { "type": "null" }]
        },
        "scenario_id": {
          "anyOf": [{ "$ref": "#/$defs/identifier" }, { "type": "null" }]
        },
        "severity": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0,
              "x-dagml-json-token-type": "binary64-float"
            },
            { "type": "null" }
          ]
        },
        "slice": { "$ref": "#/$defs/slice_key" },
        "fold_id": {
          "anyOf": [{ "$ref": "#/$defs/identifier" }, { "type": "null" }]
        },
        "repeat_id": {
          "anyOf": [{ "$ref": "#/$defs/identifier" }, { "type": "null" }]
        },
        "seed": {
          "anyOf": [
            { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
            { "type": "null" }
          ]
        },
        "unit_ids_fingerprint": {
          "$ref": "#/$defs/sha256",
          "description": "TCV1 SHA-256 of the exact, sorted physical SampleId array measured by this record. This binds slice metrics to their concrete units instead of only to a declared slice label."
        },
        "sample_count": { "type": "integer", "minimum": 1 },
        "measurement_status": { "enum": ["finite", "unbounded", "unavailable"] },
        "guarantee_status": {
          "enum": ["marginal_coverage", "joint_coverage", "diagnostic_only", "unavailable"]
        },
        "empirical_coverage": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "x-dagml-json-token-type": "binary64-float"
            },
            { "type": "null" }
          ],
          "description": "Fraction of measured units covered. Marginal records evaluate one target; joint_max records count a unit only when every target is covered."
        },
        "coverage_gap": {
          "anyOf": [
            {
              "type": "number",
              "minimum": -1,
              "maximum": 1,
              "x-dagml-json-token-type": "binary64-float"
            },
            { "type": "null" }
          ],
          "description": "empirical_coverage minus requested coverage, in that order."
        },
        "mean_width": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0,
              "x-dagml-json-token-type": "binary64-float"
            },
            { "type": "null" }
          ],
          "description": "Arithmetic mean interval width. joint_max aggregates every measured unit/target cell; null when any endpoint is unbounded or unavailable."
        },
        "median_width": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0,
              "x-dagml-json-token-type": "binary64-float"
            },
            { "type": "null" }
          ],
          "description": "Median interval width over the same cells as mean_width, using the average of the two middle values for even counts."
        },
        "interval_score": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0,
              "x-dagml-json-token-type": "binary64-float"
            },
            { "type": "null" }
          ],
          "description": "Mean two-sided Winkler interval score with alpha = 1 - coverage. joint_max aggregates every measured unit/target cell; null for unbounded/unavailable bounds."
        },
        "set_size": {
          "type": "null",
          "description": "Always null for split absolute-residual regression metrics."
        }
      }
    }
  }
}
