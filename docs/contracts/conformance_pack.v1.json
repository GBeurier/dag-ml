  "scenarios": {
    "multisource_a2_b3_c2.v1": {
      "polarity": "positive",
      "surfaces": [
        "coordinator_data_plan_envelope",
        "relation.unit_identity",
        "feature_fusion_selector",
        "source_layout"
      ],
      "fixtures": [
        "coordinator_data_plan_envelope_multisource_repetitions.v1",
        "feature_fusion_selector_nir_chem.v1"
      ],
      "test_refs": [
        "scripts/validate_contracts.py::validate_envelope",
        "scripts/validate_contracts.py::validate_feature_fusion_selector"
      ],
      "assertions": [
        "asymmetric A=2/B=3/C=2 repetitions are relation-backed observations",
        "relation and plan fingerprints are stable",
        "feature fusion remains host-owned behind selector metadata",
        "by-source preprocessing outputs declare source order and feature-axis concat spans"
      ]
    },
    "by_source_concat_layout.v1": {
      "polarity": "positive",
      "surfaces": [
        "feature_fusion_selector.source_layout",
        "source_preprocessing_output",
        "concat_layout"
      ],
      "fixtures": [
        "feature_fusion_selector_nir_chem.v1"
      ],
      "test_refs": [
        "crates/dag-ml-data-core/src/fusion.rs::source_layout_validates_source_order_and_concat_spans",
        "crates/dag-ml-data-core/src/fusion.rs::source_layout_refuses_block_order_mismatch",
        "scripts/validate_contracts.py::validate_feature_fusion_selector"
      ],
      "assertions": [
        "source_order is authoritative and matches selector source order",
        "each source block names the preprocessing output feature_set_id and representation",
        "feature-axis concat spans are contiguous and preserve source order"
      ]
    },
    "sample_level_late_fusion.v1": {
      "polarity": "positive",
      "surfaces": [
        "graph.unit_typed_ports",
        "pipeline_dsl.merge",
        "runtime.oof_prediction_inputs"
      ],
      "fixtures": [
        "oof_uc6_success_predictions.v1"
      ],
      "test_refs": [
        "crates/dag-ml-core/src/dsl.rs::parses_nirs4all_compat_feature_branch_merge_dict",
        "crates/dag-ml-core/src/runtime/tests.rs::requires_oof_prediction_edge_supplies_validated_prediction_handle"
      ],
      "assertions": [
        "late-fusion branch joins stay sample-aligned",
        "prediction inputs are OOF validation partitions",
        "merge selectors are explicit instead of positional"
      ]
    },
    "cartesian_combo_to_sample_reducer.v1": {
      "polarity": "positive",
      "surfaces": [
        "representation_plan",
        "reduction_plan",
        "aggregation_controller_task"
      ],
      "fixtures": [
        "coordinator_data_plan_envelope_multisource_repetitions.v1",
        "data_output_provenance_augmented_view.v1"
      ],
      "test_refs": [
        "crates/dag-ml-core/src/data.rs::representation_plan_validates_cartesian_and_monte_carlo_contracts",
        "crates/dag-ml-core/src/selection.rs::stacking_fit_contract_guards_oof_reuse_and_combo_reduction"
      ],
      "assertions": [
        "combo remains a relation-backed derived observation",
        "combo output requires an explicit sample-level reducer",
        "custom aggregation tasks carry input and output unit levels"
      ]
    },
    "missing_source_with_fallback.v1": {
      "polarity": "positive",
      "surfaces": [
        "representation_replay_manifest",
        "representation_compatibility_report",
        "data_output_provenance"
      ],
      "fixtures": [
        "data_output_provenance_augmented_view.v1"
      ],
      "test_refs": [
        "crates/dag-ml-core/src/data.rs::representation_compatibility_report_enforces_missingness_policy",
        "crates/dag-ml-core/src/bundle.rs::bundle_data_requirements_accept_d7_replay_contracts"
      ],
      "assertions": [
        "serve-time missing source or repetition is never silent",
        "fallback, severity and affected counts are persisted",
        "fixed-width mismatches require mask or pad policy"
      ]
    },
    "stacking_oof_contract.v1": {
      "polarity": "positive",
      "surfaces": [
        "oof_join",
        "selection_decision",
        "prediction_cache_metadata"
      ],
      "fixtures": [
        "oof_uc6_success_predictions.v1"
      ],
      "test_refs": [
        "crates/dag-ml-core/src/oof.rs::uc6_fixture_joins_successfully",
        "crates/dag-ml-core/src/runtime/tests.rs::requires_oof_prediction_edge_refit_uses_cv_oof_coverage"
      ],
      "assertions": [
        "stacking consumes validation-only OOF predictions",
        "sample ids drive joins and cache identity",
        "refit requires complete CV OOF coverage"
      ]
    },
    "invalid_unit_join.v1": {
      "polarity": "negative",
      "surfaces": [
        "graph_spec",
        "edge_contract",
        "pipeline_dsl.unit_contracts"
      ],
      "fixtures": [],
      "test_refs": [
        "crates/dag-ml-core/src/graph.rs::rejects_unit_mismatch_without_explicit_broadcast",
        "crates/dag-ml-core/src/dsl.rs::compiles_pipeline_dsl_unit_contracts_to_graph_interface"
      ],
      "assertions": [
        "observation/sample feature joins are rejected without an adapter",
        "alignment-key mismatches are actionable graph errors",
        "sample-to-non-sample broadcast must be explicit"
      ]
    },
    "row_vs_sample_selection_mismatch.v1": {
      "polarity": "negative",
      "surfaces": [
        "selection_policy",
        "selection_decision",
        "metrics"
      ],
      "fixtures": [
        "oof_uc11_train_prediction_refusal.v1"
      ],
      "test_refs": [
        "crates/dag-ml-core/src/selection.rs::selection_policy_can_require_metric_level",
        "crates/dag-ml-core/src/metrics.rs::refuses_metric_alignment_and_contract_mismatches",
        "crates/dag-ml-core/src/oof.rs::uc11_fixture_refuses_train_predictions"
      ],
      "assertions": [
        "row-level metrics cannot select a sample-level refit slot",
        "train predictions cannot become training features by default",
        "selection decisions persist the metric level used"
      ]
    },
    "operator_level_variant_additive_fields.v1": {
      "polarity": "positive",
      "surfaces": [
        "campaign_spec.generation_choice.active_subsequence",
        "execution_plan.generation_choice.active_subsequence",
        "score_set.regression_metric_report.variant_label"
      ],
      "fixtures": [],
      "test_refs": [
        "crates/dag-ml-core/src/generation.rs::additive_variant_fields_are_invisible_when_absent",
        "crates/dag-ml-core/src/generation.rs::choice_cannot_set_both_param_overrides_and_active_subsequence"
      ],
      "assertions": [
        "generation_choice carries an optional active_subsequence for operator-level variants",
        "a choice cannot set both param_overrides and active_subsequence",
        "regression_metric_report carries an optional variant_label",
        "specs/fixtures without the new fields stay byte-identical and fingerprint-stable"
      ]
    },
    "generation_constraints_prune_variants.v1": {
      "polarity": "positive",
      "surfaces": [
        "campaign_spec.generation_spec.constraints",
        "campaign_spec.generation_constraints.mutex",
        "campaign_spec.generation_constraints.requires",
        "campaign_spec.generation_constraints.exclude",
        "campaign_spec.choice_ref"
      ],
      "fixtures": [],
      "test_refs": [
        "crates/dag-ml-core/src/generation.rs::constraint_mutex_prunes_pair",
        "crates/dag-ml-core/src/generation.rs::constraint_mutex_group_of_three_forbids_only_full_co_occurrence",
        "crates/dag-ml-core/src/generation.rs::constraint_requires_prunes",
        "crates/dag-ml-core/src/generation.rs::constraint_exclude_prunes_pair",
        "crates/dag-ml-core/src/generation.rs::constraint_cartesian_exclude_prunes_one_of_four",
        "crates/dag-ml-core/src/generation.rs::constraint_combined_mutex_and_exclude",
        "crates/dag-ml-core/src/generation.rs::constraint_prunes_to_one",
        "crates/dag-ml-core/src/generation.rs::constraints_absent_keep_spec_byte_identical",
        "crates/dag-ml-core/src/dsl/tests.rs::compiles_generation_constraints_and_prunes_variants"
      ],
      "assertions": [
        "generation_spec carries an optional constraints block (mutex / requires / exclude over choice_ref)",
        "_depends_on_ is a dead keyword and is not represented",
        "mutex prunes only the variant where the FULL group co-occurs (legacy issubset rule: a pair forbids 'both present', a 3+ group forbids only the all-present variant and keeps every proper subset), requires enforces dependency, exclude forbids a pair",
        "the surviving variant set matches the nirs4all generation oracle's documented counts",
        "a spec without constraints stays byte-identical and fingerprint-stable"
      ]
    }
  },
