{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GBeurier/dag-ml/schemas/training_outcome.v2.schema.json",
  "title": "DAG-ML TrainingOutcome v2",
  "description": "TrainingOutcome migration target for port-explicit bound outputs and V2 prediction-cache manifests and payloads. Plan, selection and influence contracts remain unchanged from V1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "outcome_id",
    "run_id",
    "training_request_fingerprint",
    "data_identities",
    "effective_plan",
    "effective_plan_fingerprint",
    "selected_variant_id",
    "selected_variant_fingerprint",
    "selection_output_id",
    "parameter_patches",
    "refit",
    "score_set",
    "outputs",
    "lineage",
    "portable_prediction_caches",
    "training_influence",
    "execution_bundle",
    "replayable_phases",
    "warnings",
    "diagnostics",
    "outcome_fingerprint"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 2 },
    "outcome_id": { "$ref": "#/$defs/identifier" },
    "run_id": { "$ref": "#/$defs/identifier" },
    "training_request_fingerprint": { "$ref": "#/$defs/sha256" },
    "data_identities": {
      "type": "array",
      "items": {
        "$ref": "https://github.com/GBeurier/dag-ml/schemas/training_request.v1.schema.json#/$defs/training_data_identity"
      }
    },
    "effective_plan": {
      "$ref": "https://github.com/GBeurier/dag-ml/schemas/execution_plan.v1.schema.json"
    },
    "effective_plan_fingerprint": { "$ref": "#/$defs/sha256" },
    "selected_variant_id": { "$ref": "#/$defs/identifier" },
    "selected_variant_fingerprint": { "$ref": "#/$defs/sha256" },
    "selection_output_id": { "$ref": "#/$defs/identifier" },
    "parameter_patches": {
      "type": "array",
      "items": {
        "$ref": "https://github.com/GBeurier/dag-ml/schemas/parameter_patch.v1.schema.json"
      },
      "default": []
    },
    "refit": {
      "$ref": "https://github.com/GBeurier/dag-ml/schemas/training_outcome.v1.schema.json#/$defs/refit_outcome"
    },
    "score_set": {
      "$ref": "https://github.com/GBeurier/dag-ml/schemas/score_set.v2.schema.json"
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://github.com/GBeurier/dag-ml/schemas/bound_training_output.v2.schema.json"
      }
    },
    "lineage": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://github.com/GBeurier/dag-ml/schemas/node_result.v1.schema.json#/$defs/lineage_record"
      }
    },
    "portable_prediction_caches": {
      "anyOf": [
        {
          "$ref": "https://github.com/GBeurier/dag-ml/schemas/prediction_cache_payload_set.v2.schema.json"
        },
        { "type": "null" }
      ],
      "default": null
    },
    "training_influence": {
      "$ref": "https://github.com/GBeurier/dag-ml/schemas/training_influence_manifest.v1.schema.json"
    },
    "execution_bundle": {
      "$ref": "https://github.com/GBeurier/dag-ml/schemas/execution_bundle.v2.schema.json"
    },
    "replayable_phases": {
      "type": "array",
      "uniqueItems": true,
      "items": { "enum": ["REFIT", "PREDICT", "EXPLAIN"] }
    },
    "warnings": {
      "type": "array",
      "default": [],
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "diagnostics": {
      "type": "object",
      "default": {},
      "additionalProperties": true
    },
    "outcome_fingerprint": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "non_empty_string": { "type": "string", "minLength": 1 },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
