{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GBeurier/dag-ml/schemas/portable_predictor_package.v1.schema.json",
  "title": "DAG-ML PortablePredictorPackage v1",
  "description": "Portable predictor descriptor linking template, request/outcome references, effective plan, bundle, output bindings, exact predictor closure, influence, data identity and explicit native-versus-host artifact loading. Runtime handles are forbidden recursively.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "package_id",
    "template",
    "training_request_fingerprint",
    "training_outcome",
    "effective_plan",
    "execution_bundle",
    "output_bindings",
    "predictor_node_ids",
    "training_influence",
    "data_identities",
    "fitted_artifact_mode",
    "artifact_bindings",
    "package_fingerprint"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "package_id": { "$ref": "#/$defs/identifier" },
    "template": { "$ref": "#/$defs/predictor_template" },
    "training_request_fingerprint": { "$ref": "#/$defs/sha256" },
    "training_outcome": { "$ref": "#/$defs/training_outcome_ref" },
    "effective_plan": {
      "$ref": "https://github.com/GBeurier/dag-ml/schemas/execution_plan.v1.schema.json"
    },
    "execution_bundle": {
      "$ref": "https://github.com/GBeurier/dag-ml/schemas/execution_bundle.v1.schema.json"
    },
    "output_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://github.com/GBeurier/dag-ml/schemas/output_binding.v1.schema.json"
      },
      "description": "Strictly sorted by binding_id; coordinates are unique."
    },
    "predictor_node_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" },
      "description": "Strictly sorted exact transitive closure of output nodes."
    },
    "training_influence": {
      "$ref": "https://github.com/GBeurier/dag-ml/schemas/training_influence_manifest.v1.schema.json"
    },
    "data_identities": {
      "type": "array",
      "items": {
        "$ref": "https://github.com/GBeurier/dag-ml/schemas/training_request.v1.schema.json#/$defs/training_data_identity"
      }
    },
    "fitted_artifact_mode": {
      "enum": ["portable_required", "allow_host_sidecar"]
    },
    "artifact_bindings": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact_binding" },
      "description": "Strictly sorted and exactly covers execution_bundle.refit_artifacts."
    },
    "package_fingerprint": {
      "$ref": "#/$defs/sha256",
      "description": "DAG-ML TCV1 SHA-256 of this complete package with only package_fingerprint omitted."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "fitted_artifact_mode": { "const": "portable_required" } },
        "required": ["fitted_artifact_mode"]
      },
      "then": {
        "properties": {
          "artifact_bindings": {
            "items": {
              "properties": { "load_mode": { "const": "native_portable" } }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "predictor_template": {
      "type": "object",
      "additionalProperties": false,
      "required": ["graph", "campaign", "controller_manifests", "template_fingerprint"],
      "properties": {
        "graph": {
          "$ref": "https://github.com/GBeurier/dag-ml/schemas/graph_spec.v1.schema.json"
        },
        "campaign": {
          "$ref": "https://github.com/GBeurier/dag-ml/schemas/campaign_spec.v1.schema.json"
        },
        "controller_manifests": {
          "type": "object",
          "additionalProperties": {
            "$ref": "https://github.com/GBeurier/dag-ml/schemas/controller_manifest.v1.schema.json"
          }
        },
        "template_fingerprint": { "$ref": "#/$defs/sha256" }
      }
    },
    "training_outcome_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outcome_id",
        "outcome_fingerprint",
        "training_request_fingerprint",
        "effective_plan_fingerprint",
        "execution_bundle_id",
        "execution_bundle_fingerprint",
        "output_binding_fingerprints",
        "training_influence_fingerprint",
        "data_identities_fingerprint"
      ],
      "properties": {
        "outcome_id": { "$ref": "#/$defs/identifier" },
        "outcome_fingerprint": { "$ref": "#/$defs/sha256" },
        "training_request_fingerprint": { "$ref": "#/$defs/sha256" },
        "effective_plan_fingerprint": { "$ref": "#/$defs/sha256" },
        "execution_bundle_id": { "$ref": "#/$defs/identifier" },
        "execution_bundle_fingerprint": {
          "$ref": "#/$defs/sha256",
          "description": "TCV1 SHA-256 of the complete execution_bundle embedded by the package."
        },
        "output_binding_fingerprints": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/sha256" }
        },
        "training_influence_fingerprint": { "$ref": "#/$defs/sha256" },
        "data_identities_fingerprint": {
          "$ref": "#/$defs/sha256",
          "description": "TCV1 SHA-256 of the complete canonically ordered TrainingDataIdentity array."
        }
      }
    },
    "artifact_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "load_mode"],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/identifier" },
        "load_mode": { "enum": ["native_portable", "host_sidecar"] }
      }
    }
  }
}
