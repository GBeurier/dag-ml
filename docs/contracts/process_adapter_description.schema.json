{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GBeurier/dag-ml/schemas/process_adapter_description.v1.schema.json",
  "title": "DAG-ML Process Adapter Description v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "protocol",
    "adapter_id",
    "supported_modes",
    "capabilities"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "protocol": {
      "const": "dag-ml-process-adapter"
    },
    "adapter_id": {
      "$ref": "#/$defs/identifier"
    },
    "supported_modes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["one_shot", "jsonl"]
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/capability"
      },
      "allOf": [
        {
          "contains": {
            "const": "node_task_json_v1"
          }
        },
        {
          "contains": {
            "const": "node_result_json_v1"
          }
        }
      ]
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "capability": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9_.:-]+$"
    }
  }
}
