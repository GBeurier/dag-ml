{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GBeurier/dag-ml/schemas/conformal_prediction_block.v1.schema.json",
  "title": "DAG-ML ConformalPredictionBlock v1",
  "description": "Identity-aligned split absolute-residual intervals for one frozen point-prediction block. Domain support and accept/reject decisions are deliberately excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "block_id",
    "calibration_artifact_id",
    "calibration_artifact_checksum",
    "predictor_binding_fingerprint",
    "cohort_manifest_fingerprint",
    "point_prediction_fingerprint",
    "point_output_binding",
    "method",
    "numeric_version",
    "unit_level",
    "prediction_level",
    "unit_ids",
    "target_names",
    "multi_target_policy",
    "intervals",
    "assumption_status",
    "guarantee_status",
    "block_fingerprint"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "block_id": {
      "$ref": "https://github.com/GBeurier/dag-ml/schemas/conformal_calibration.v1.schema.json#/$defs/identifier"
    },
    "calibration_artifact_id": {
      "$ref": "https://github.com/GBeurier/dag-ml/schemas/conformal_calibration.v1.schema.json#/$defs/identifier"
    },
    "calibration_artifact_checksum": {
      "$ref": "https://github.com/GBeurier/dag-ml/schemas/conformal_calibration.v1.schema.json#/$defs/sha256"
    },
    "predictor_binding_fingerprint": {
      "$ref": "https://github.com/GBeurier/dag-ml/schemas/conformal_calibration.v1.schema.json#/$defs/sha256"
    },
    "cohort_manifest_fingerprint": {
      "$ref": "https://github.com/GBeurier/dag-ml/schemas/conformal_calibration.v1.schema.json#/$defs/sha256"
    },
    "point_prediction_fingerprint": {
      "$ref": "https://github.com/GBeurier/dag-ml/schemas/conformal_calibration.v1.schema.json#/$defs/sha256"
    },
    "point_output_binding": {
      "$ref": "https://github.com/GBeurier/dag-ml/schemas/conformal_calibration.v1.schema.json#/$defs/conformal_output_binding"
    },
    "method": { "const": "split_absolute_residual" },
    "numeric_version": { "const": "split_absolute_residual.v1" },
    "unit_level": { "const": "physical_sample" },
    "prediction_level": { "const": "sample" },
    "unit_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "https://github.com/GBeurier/dag-ml/schemas/conformal_calibration.v1.schema.json#/$defs/identifier"
      },
      "description": "Lexicographically sorted unique physical SampleId values. Semantic validation enforces ordering."
    },
    "target_names": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "https://github.com/GBeurier/dag-ml/schemas/conformal_calibration.v1.schema.json#/$defs/non_empty_string"
      }
    },
    "multi_target_policy": { "enum": ["marginal", "joint_max"] },
    "intervals": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/coverage_interval" },
      "description": "Strictly increasing unique coverages. Bounds are nested across increasing coverages."
    },
    "assumption_status": {
      "enum": ["declared_exchangeable", "distribution_shift", "not_assessed"],
      "description": "Explicit applicability of the exchangeability assumption for this prediction cohort. Finite bounds alone never imply a formal coverage claim."
    },
    "guarantee_status": {
      "enum": ["marginal_coverage", "joint_coverage", "diagnostic_only", "unavailable"]
    },
    "block_fingerprint": {
      "$ref": "https://github.com/GBeurier/dag-ml/schemas/conformal_calibration.v1.schema.json#/$defs/sha256",
      "description": "DAG-ML TCV1 SHA-256 of the complete block with block_fingerprint omitted."
    }
  },
  "$defs": {
    "bound_matrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "array",
        "minItems": 1,
        "items": {
          "anyOf": [
            {
              "type": "number",
              "x-dagml-json-token-type": "binary64-float"
            },
            { "type": "null" }
          ],
          "description": "Finite binary64 bound, or null for an unbounded endpoint. For split_absolute_residual.v1, lower and upper must both be null for the same unit/target cell."
        }
      }
    },
    "coverage_interval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coverage", "lower", "upper"],
      "properties": {
        "coverage": {
          "type": "number",
          "exclusiveMinimum": 0,
          "exclusiveMaximum": 1,
          "x-dagml-json-token-type": "binary64-float"
        },
        "lower": { "$ref": "#/$defs/bound_matrix" },
        "upper": { "$ref": "#/$defs/bound_matrix" }
      }
    }
  }
}
